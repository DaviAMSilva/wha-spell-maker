{
    "name": "wha-spell-maker",
    "type": "module",
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "@json-editor/json-editor": "^2.16.0",
        "bootstrap": "^5.3.8",
        "handlebars": "^4.7.8",
        "mini-jsx": "^4.0.0",
        "p5": "^2.2.2"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.30.2",
        "@cloudflare/workers-types": "^4.20260408.1",
        "@eslint/js": "^10.0.1",
        "@types/p5": "^1.7.7",
        "eslint": "^10.0.3",
        "json-schema-to-typescript": "^15.0.4",
        "json-to-ts": "^2.1.0",
        "sass": "^1.97.3",
        "terser": "^5.46.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1",
        "wrangler": "^4.78.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "npm run make && vite build",
        "preview": "npm run build && wrangler dev",
        "clean": "rm -fr dist",
        "make": "npm run symbols && npm run types",
        "symbols": "python3 tools/symbols.py",
        "types": "for f in src/schemas/*.json; do npx json2ts \"$f\" > \"types/$(basename \"${f%.json}.d.ts\")\"; done",
        "deploy": "npm run build && wrangler deploy"
    }
}
